# PostgreSQL — fourni automatiquement par Railway si tu ajoutes un plugin Postgres
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Resend — récupère ta clé sur resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email qui reçoit les notifications de nouveaux devis/rendez-vous
WEBORA_ADMIN_EMAIL=derdoummyasser@gmail.com

# (optionnel) Adresse expéditeur — nécessite un domaine vérifié sur Resend
# WEBORA_FROM_EMAIL=Webora <contact@ton-domaine.fr>

# Port (Railway le définit automatiquement)
PORT=8080
